RewriteEngine On

# Redirect explicit .php requests to extensionless URL
# Only do this for browser GET requests, not POST form submissions
# Example: /project/invoice.php -> /project/invoice
RewriteCond %{REQUEST_METHOD} =GET
RewriteCond %{THE_REQUEST} \s/+(.+?)\.php(?:[\s?]|$) [NC]
RewriteRule ^ /%1 [R=301,L,NE]

# Internally map extensionless requests to .php files
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^(.+?)/?$ $1.php [L]
